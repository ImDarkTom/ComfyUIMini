<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: "Import a workflow", theme }) %>
    <link rel="stylesheet" href="/css/import.css">
    <script src="/js/pages/import2.js" type="module" defer></script>
    <script src="/js/common/popupWindow.js" defer></script>
</head>
<body>
    <div class="main-container">
        <div class="file-select-container">
            <label for="file-input" class="file-input-label">Select a workflow file</label>
            <input type="file" id="file-input" class="file-input" accept=".json">
        </div>
    </div>
    <%- include('../partials/actionBar', {
        buttons: [
            { action: "/", icon: "home", text: "Home", type: "link" },
            { action: ["/js/common/scroll.js", "scrollToBottom"], icon: "arrow-down", text: "Bottom", type: "function" },
            { action: ["/js/pages/import.js", "scrollToSaveButtons"], icon: "save", text: "Save", type: "function" },
            { action: ["/js/common/scroll.js", "scrollToTop"], icon: "arrow-up", text: "Top", type: "function" },
            { action: "/settings", icon: "settings", text: "Settings", type: "link" },
        ] 
    }) %>
</body>
</html>